<span class="field field--name-uid field--type-entity-reference field--label-hidden"><a title="View user profile." href="https://opensource.com/users/admin" class="username">admin</a></span>
<span class="field field--name-created field--type-created field--label-hidden"><time datetime="2023-06-06T13:30:00-04:00" title="Tuesday, June 6, 2023 - 13:30" class="datetime">Tue, 06/06/2023 - 13:30</time>
